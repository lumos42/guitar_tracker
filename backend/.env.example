PYTHONPATH=.

# Application
APP_ENV=development
APP_BASE_URL=http://localhost:9000
FRONTEND_URL=http://localhost:5173

# Database (SQLite for dev; change DB_PATH for a different location)
DB_PATH=./guitar_tracker.db

# JWT — generate secret with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:9000/api/v1/auth/google/callback

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# File Storage
UPLOAD_DIR=/var/www/guitar_tracker/uploads
MAX_FILE_SIZE_MB=200

# spotdl — full path to the spotdl binary (use venv path in production)
SPOTDL_PATH=spotdl
# Optional: path to spotdl config file (can include cookies_path, auth tokens, etc.)
SPOTDL_CONFIG=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cookie
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
